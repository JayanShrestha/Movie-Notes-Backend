generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id        Int   @id @default(autoincrement()) @db.Integer
  email     String   @unique @db.VarChar(100)
  name      String?  @unique @db.VarChar(100)
  password  String   @db.VarChar(255) 
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  reviews Reviews[] // Relation to Reviews model
}

model Movies {
  id           Int   @id @default(autoincrement()) @db.Integer
  title        String   @db.VarChar(255)
  overview     String?  @db.Text
  tmdb_id      Int      @unique
  poster_path  String?
  backdrop_path String? @db.VarChar(255)
  genres       Json
  release_date String   @db.VarChar(20)
  runtime      Int?     @db.Integer
  vote_average Float?
  vote_count Int?
  createdAt DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)



  reviews Reviews[] // Relation to Reviews model
}

model Reviews {
  id       Int      @id @default(autoincrement()) @db.Integer 
  user_Id    Int
  movie_Id   Int
  rating    Float
  review_text   String?  @db.Text
  createdAt DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @db.Timestamptz(6)
  user      Users        @relation(fields: [user_Id], references: [id])// foregin key to Users model
  movie     Movies       @relation(fields: [movie_Id], references: [id])// foregin key to Movies model

 
}
